---
import type { CollectionEntry } from 'astro:content';
import { SHOP_LIVE, SITE } from '../lib/config';
import AntennaViz from './viz/AntennaViz.astro';
import BlochViz from './viz/BlochViz.astro';
import ScopeViz from './viz/ScopeViz.astro';
import DiamondViz from './viz/DiamondViz.astro';
import PreprintViz from './viz/PreprintViz.astro';
import FlaskViz from './viz/FlaskViz.astro';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const {
  name,
  nameAccent,
  category,
  categoryLabel,
  blurb,
  price,
  priceUnit,
  stripePaymentLink,
  vizComponent,
} = product.data;

const VizMap = {
  AntennaViz,
  BlochViz,
  ScopeViz,
  DiamondViz,
  PreprintViz,
  FlaskViz,
} as const;
const Viz = VizMap[vizComponent];

const detailHref = `/shop/${product.slug}`;
const buyHref = SHOP_LIVE ? (stripePaymentLink ?? detailHref) : `mailto:${SITE.email}?subject=Notify%20me%3A%20${encodeURIComponent(name)}`;
const buyLabel = SHOP_LIVE
  ? category === 'service'
    ? 'Book a slot →'
    : category === 'digital'
      ? 'Buy access →'
      : 'Add to cart →'
  : 'Notify me ↗';
---

<a class="product" href={SHOP_LIVE ? detailHref : buyHref} data-category={category}>
  <div class="product-img">
    <Viz />
  </div>
  <div class="product-body">
    <span class="product-cat">{categoryLabel}</span>
    <h3 class="product-name">
      {name}{nameAccent && <> <em>{nameAccent}</em></>}
    </h3>
    <p class="product-desc">{blurb}</p>
    <div class="product-foot">
      <span class="product-price">{price}{priceUnit && <small> {priceUnit}</small>}</span>
      <span class="product-buy">{buyLabel}</span>
    </div>
  </div>
</a>

<style>
  .product {
    border: 1px solid var(--rule);
    background: var(--ink-2);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }
  .product:hover { border-color: var(--bone-faint); }
  .product-img {
    aspect-ratio: 4/3;
    background: var(--ink-3);
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }
  .product-img :global(svg) { width: 100%; height: 100%; display: block; }
  .product-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .product-cat {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--phosphor);
  }
  .product-name {
    font-family: var(--display);
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--bone);
  }
  .product-name em { font-style: italic; font-weight: 300; }
  .product-desc {
    font-size: 0.9rem;
    color: var(--bone-dim);
    flex: 1;
    line-height: 1.5;
  }
  .product-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 1rem;
    margin-top: 0.5rem;
    border-top: 1px dashed var(--rule);
  }
  .product-price {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--bone);
    font-weight: 500;
  }
  .product-price small {
    color: var(--bone-faint);
    font-weight: 400;
    font-size: 0.78rem;
  }
  .product-buy {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--phosphor);
  }
  .product-buy:hover { color: var(--bone); }
</style>
