---
// NV-center diamond lattice glyph — used by magnetometer product.
---
<svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
  <rect width="200" height="150" fill="#111614" />
  <g stroke="#7eff9f" fill="none" stroke-width="1">
    <line x1="50" y1="40" x2="100" y2="60" />
    <line x1="100" y1="60" x2="150" y2="40" />
    <line x1="100" y1="60" x2="100" y2="110" />
    <line x1="50" y1="40" x2="50" y2="90" />
    <line x1="150" y1="40" x2="150" y2="90" />
    <line x1="50" y1="90" x2="100" y2="110" />
    <line x1="100" y1="110" x2="150" y2="90" />
    <circle cx="50" cy="40" r="3" fill="#7eff9f" />
    <circle cx="150" cy="40" r="3" fill="#7eff9f" />
    <circle cx="100" cy="60" r="4" fill="#c9543a" />
    <circle cx="100" cy="110" r="3" fill="#7eff9f" />
    <circle cx="50" cy="90" r="3" fill="#7eff9f" />
    <circle cx="150" cy="90" r="3" fill="#7eff9f" />
  </g>
  <text x="10" y="140" font-family="JetBrains Mono, monospace" font-size="6" fill="#6a685e">NV-CENTER // PRE-ORDER</text>
</svg>
