---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import PaperRow from '../../components/PaperRow.astro';

const papers = (await getCollection('papers')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Research — Tardigrade Innovation"
  description="Preprints, working drafts, and code releases from Tardigrade Innovation."
>
  <Section
    id="research"
    index="§ 02 — WRITTEN"
    title="{accent} log."
    titleAccent="Research"
    blurb="Preprints, working drafts, and code releases. Most are independent; the VQE/LIGO work is a collaboration with a UCSB PhD candidate."
    background="ink-2"
    bordered
  >
    <div class="research-list">
      {papers.map((p) => <PaperRow paper={p} />)}
    </div>
  </Section>
</BaseLayout>

<style>
  .research-list { display: flex; flex-direction: column; }
</style>
