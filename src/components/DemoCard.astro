---
import type { CollectionEntry } from 'astro:content';
import WaveformViz from './viz/WaveformViz.astro';
import BlochViz from './viz/BlochViz.astro';
import LatticeViz from './viz/LatticeViz.astro';
import PreprintViz from './viz/PreprintViz.astro';
import ScopeViz from './viz/ScopeViz.astro';

interface Props {
  demo: CollectionEntry<'demos'>;
  size: 'large' | 'small';
}

const { demo, size } = Astro.props;
const { number, title, titleAccent, blurb, tags, vizComponent } = demo.data;

const VizMap = {
  WaveformViz,
  BlochViz,
  LatticeViz,
  PreprintViz,
  ScopeViz,
} as const;

const Viz = VizMap[vizComponent];
const href = `/lab/${demo.slug}`;
---

<a class:list={['demo', `demo-${size}`]} href={href}>
  <span class="demo-launch">{size === 'large' ? 'LAUNCH ↗' : '↗'}</span>
  <span class="demo-num">DEMO / {number}</span>
  <h3>
    {title}{titleAccent && <> <em>{titleAccent}</em></>}
  </h3>
  {size === 'large' && (
    <div class="mini-viz">
      <Viz />
    </div>
  )}
  <p>{blurb}</p>
  <div class="demo-tags">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</a>

<style>
  .demo {
    background: var(--ink-2);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
    min-height: 280px;
  }
  .demo:hover { background: var(--ink-3); }
  .demo-large { grid-column: span 6; min-height: 360px; }
  .demo-small { grid-column: span 4; }
  @media (max-width: 900px) {
    .demo-large, .demo-small { grid-column: span 12; }
  }

  .demo-num {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--phosphor);
    letter-spacing: 0.12em;
  }
  .demo h3 {
    font-family: var(--display);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--bone);
  }
  .demo h3 em { font-style: italic; font-weight: 300; }
  .demo p {
    font-size: 0.92rem;
    color: var(--bone-dim);
    flex: 1;
  }
  .demo-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.75rem;
  }
  .demo-launch {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--phosphor);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s;
  }
  .demo:hover .demo-launch {
    opacity: 1;
    transform: translateX(0);
  }

  .mini-viz {
    margin: 0.5rem 0 1rem;
    height: 90px;
    border: 1px solid var(--rule);
    background:
      linear-gradient(180deg, rgba(126, 255, 159, 0.06), transparent),
      radial-gradient(circle at 20% 50%, rgba(126, 255, 159, 0.15), transparent 40%);
    position: relative;
    overflow: hidden;
  }
  .mini-viz :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
