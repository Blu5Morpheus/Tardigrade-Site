---
// Yagi antenna schematic — used by L-band receiver product.
---
<svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
  <defs>
    <linearGradient id="ant-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#1a201d" />
      <stop offset="1" stop-color="#0a0d0c" />
    </linearGradient>
  </defs>
  <rect width="200" height="150" fill="url(#ant-bg)" />
  <line x1="40" y1="115" x2="160" y2="115" stroke="#7eff9f" stroke-width="1" />
  <line x1="100" y1="115" x2="100" y2="40" stroke="#7eff9f" stroke-width="1" />
  <line x1="70" y1="55" x2="130" y2="55" stroke="#7eff9f" stroke-width="1" />
  <line x1="80" y1="65" x2="120" y2="65" stroke="#7eff9f" stroke-width="1" />
  <line x1="88" y1="75" x2="112" y2="75" stroke="#7eff9f" stroke-width="1" />
  <circle cx="100" cy="115" r="3" fill="#7eff9f" />
  <circle cx="40" cy="115" r="2" fill="#7eff9f" />
  <circle cx="160" cy="115" r="2" fill="#7eff9f" />
  <text x="10" y="140" font-family="JetBrains Mono, monospace" font-size="6" fill="#6a685e">L-BAND // 1420 MHz</text>
</svg>
